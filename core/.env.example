# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=books
DB_USER=books
DB_PASSWORD=books

# FileMaker Data API
FILEMAKER_BASE_URL=https://your-fm-server.example.com
FILEMAKER_DB=YourDatabase
FILEMAKER_LAYOUT=Books
FILEMAKER_USER=admin
FILEMAKER_PASSWORD=secret

# Craft CMS
CRAFTCMS_BASE_URL=https://your-craft-site.example.com
CRAFTCMS_TOKEN=your-api-token

# Dev mode: route pushers to local stub servers
USE_STUBS=true
FM_STUB_PORT=5001
CRAFT_STUB_PORT=5002

# Scheduler
PUSH_INTERVAL_SECONDS=300
PUSH_TARGETS=filemaker,craftcms
